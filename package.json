{
  "name": "toastflux",
  "version": "1.0.10",
  "description": "A lightweight, beautiful, and fully customizable toast notification library for React & Next.js with modern UI, themes, actions, and progress support.",
  "author": "Rahul",
  "license": "MIT",
  "keywords": [
    "toast",
    "toast notification",
    "react toast",
    "nextjs toast",
    "notification",
    "react notification",
    "toast library",
    "ui toast",
    "alert",
    "snackbar",
    "toastflux"
  ],
  "main": "./packages/react/dist/index.js",
  "module": "./packages/react/dist/index.mjs",
  "types": "./packages/react/dist/index.d.ts",
  "files": [
    "packages/react/dist",
    "packages/core/dist",
    "packages/styles",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./packages/react/dist/index.d.ts",
      "import": "./packages/react/dist/index.mjs",
      "require": "./packages/react/dist/index.js"
    },
    "./styles/toast.css": "./packages/styles/toast.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "homepage": "https://toastflux.versintal.in",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rahul-Bairwa/toastflux.git"
  },
  "funding": {
    "type": "individual",
    "url": "https://github.com/sponsors/Rahul-Bairwa"
  },
  "bugs": {
    "url": "https://github.com/Rahul-Bairwa/toastflux/issues"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "workspaces": [
    "packages/*",
    "apps/react-app"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
