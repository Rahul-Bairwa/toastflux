{
    "compilerOptions": {
        "target": "ES2018",
        "lib": [
            "DOM",
            "ESNext"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "baseUrl": ".",
        "paths": {
            "@your-lib/core": [
                "packages/core/src"
            ],
            "@your-lib/react": [
                "packages/react/src"
            ]
        }
    }
}